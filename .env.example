# =============================================================================
# Parroquia Castrense de Santa Margarita — variables de entorno
# Copiar como .env y ajustar los valores para cada entorno.
# NUNCA commitear el archivo .env real al repositorio.
# =============================================================================

# Nombre del sitio (aparece en el <title> y en el pie de página)
APP_NAME="Parroquia Castrense de Santa Margarita"

# Entorno: local | production
APP_ENV=local

# Mostrar errores detallados (false en producción)
APP_DEBUG=true

# URL base del sitio sin barra final
APP_URL=http://localhost:8000

# Subpath del sitio en el servidor (vacío en dominio raíz, /parroquiamargarita en GitHub Pages)
APP_BASE_PATH=

# Locale por defecto (es | ca | en)
APP_LOCALE=es
